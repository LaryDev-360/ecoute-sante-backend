# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL via Docker — see docker-compose.yml)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/sante_ecoute

# CORS (comma-separated origins for frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# E-mail (console backend in dev — OTP printed to runserver logs)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@sante-ecoute.bj

# OpenRouter (classification IA — modèle gratuit recommandé : openrouter/free)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_TIMEOUT=15
OPENROUTER_APP_URL=http://localhost:8000

# Mistral (médiateur vocal Gbègbe — modèle audio Voxtral)
MISTRAL_API_KEY=
MISTRAL_MODEL=voxtral-small-latest
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_TIMEOUT=30

# Green API (WhatsApp)
GREEN_API_ID_INSTANCE=
GREEN_API_TOKEN=
GREEN_API_BASE_URL=https://api.green-api.com
GREEN_API_TIMEOUT=30
# Prompts vocaux (note vocale TTS française) à chaque étape — true/false
WHATSAPP_VOICE_PROMPTS=true
# URL publique du serveur (tunnel ngrok/cloudflare) où Green API récupère les MP3.
# Ex : https://xxxx.trycloudflare.com  (laisser vide désactive la voix)
WHATSAPP_PUBLIC_BASE_URL=
# Optionnel : si renseigné, le webhook /whatsapp/webhook/ exige cet en-tête Authorization: Bearer <token>
GREEN_API_WEBHOOK_TOKEN=

# --- Production (config/settings/prod.py) ---
# SECRET_KEY=<long-random-secret>
# DEBUG=False
# ALLOWED_HOSTS=api.sante-ecoute.bj,www.sante-ecoute.bj
# DATABASE_URL=postgres://user:pass@host:5432/sante_ecoute
# CORS_ALLOWED_ORIGINS=https://app.sante-ecoute.bj
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

