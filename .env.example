# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL via Docker — see docker-compose.yml)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/sante_ecoute

# CORS (comma-separated origins, used in later phases)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# E-mail (console backend in dev — OTP printed to runserver logs)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@sante-ecoute.ci
